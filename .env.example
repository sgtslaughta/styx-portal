# ── Styx Portal configuration ────────────────────────────────
# Your portal domain. Instances are served under /i/<name> on this host.
DOMAIN=portal.example.com

# ── Ingress / TLS ────────────────────────────────────────────
# "tunnel" = Cloudflare Tunnel (TLS terminates at Cloudflare's edge), default.
# "direct" = Traefik owns ports 80/443 with automatic Let's Encrypt wildcard TLS.
# COMPOSE_PROFILES selects which ingress containers start; keep it equal to DEPLOY_MODE.
COMPOSE_PROFILES=tunnel
DEPLOY_MODE=tunnel

# tunnel mode only — your Cloudflare Tunnel token:
CF_TUNNEL_TOKEN=

# direct mode only — Let's Encrypt via DNS-01 for wildcard *.${DOMAIN} certs.
# Example uses Cloudflare DNS; for other providers see Traefik's ACME docs and
# adjust traefik/traefik-direct.yml + the env var name.
#LE_EMAIL=you@example.com
#CF_DNS_API_TOKEN=

# ── Secrets ──────────────────────────────────────────────────
# Leave JWT_SECRET empty: a strong secret is generated on first start and saved
# to the data volume (/app/data/secrets.json, mode 0600). BACK THAT FILE UP —
# losing it logs everyone out and invalidates stored OAuth client secrets.
# To pin your own instead: openssl rand -base64 48
JWT_SECRET=

# ── Cookies ──────────────────────────────────────────────────
# true (default) requires HTTPS end to end. Set false ONLY for local plain-HTTP dev.
COOKIE_SECURE=true

# ── Limits ───────────────────────────────────────────────────
# Max concurrent instances per non-admin user (0 = unlimited; admins exempt).
MAX_INSTANCES_PER_USER=3

# ── GPU (optional) ───────────────────────────────────────────
# Numeric GIDs that own /dev/dri on the HOST, granting the backend GPU access.
# Find yours: getent group video render   (e.g. video:x:44, render:x:992)
# Wrong values still boot; GPU just won't be accessible until corrected.
VIDEO_GID=44
RENDER_GID=992

# ── Optional ─────────────────────────────────────────────────
# Override the OAuth redirect base (defaults to https://${DOMAIN}):
#OAUTH_REDIRECT_BASE=

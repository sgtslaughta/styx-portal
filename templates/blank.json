{
  "name": "blank",
  "display_name": "Blank Desktop",
  "image": "ghcr.io/linuxserver/baseimage-selkies:debiantrixie",
  "icon": "\ud83d\udcc4",
  "description": "Minimal desktop \u2014 clean slate with a single persistent volume",
  "env_vars": {
    "PUID": "1000",
    "PGID": "1000"
  },
  "gpu_enabled": false,
  "gpu_count": 0,
  "memory_limit": "2g",
  "cpu_limit": "1.0",
  "shm_size": "512m",
  "volumes": [
    {
      "name": "{instance_id}-home",
      "mount": "/config"
    }
  ],
  "internal_port": 3001,
  "internal_protocol": "https",
  "tls_skip_verify": true,
  "category": "desktop",
  "tags": [
    "minimal",
    "blank"
  ],
  "session_config": {
    "idle_timeout": "30m",
    "grace_period": "5m",
    "timeout_action": "stop",
    "never_timeout": false,
    "max_session_duration": null
  },
  "cap_add": [
    "CHOWN",
    "DAC_OVERRIDE",
    "FSETID",
    "FOWNER",
    "MKNOD",
    "NET_RAW",
    "SETGID",
    "SETUID",
    "SETFCAP",
    "SETPCAP",
    "NET_BIND_SERVICE",
    "SYS_CHROOT",
    "KILL",
    "AUDIT_WRITE"
  ],
  "security_opt": [
    "seccomp=unconfined",
    "apparmor=unconfined"
  ]
}

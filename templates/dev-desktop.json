{
  "name": "dev-desktop",
  "display_name": "Developer Workstation",
  "image": "selkies-desktop:latest",
  "icon": "\ud83d\udee0\ufe0f",
  "description": "XFCE dev workstation \u2014 VSCode, PyCharm, Node, Python, git, Firefox, Chrome, btop, dark theme",
  "env_vars": {
    "PUID": "1000",
    "PGID": "1000",
    "PIXELFLUX_WAYLAND": "true",
    "TITLE": "Developer Workstation"
  },
  "gpu_enabled": true,
  "gpu_count": 1,
  "memory_limit": "8g",
  "cpu_limit": "4.0",
  "shm_size": "2g",
  "dind": true,
  "volumes": [
    {
      "name": "{instance_id}-home",
      "mount": "/config"
    }
  ],
  "internal_port": 3000,
  "internal_protocol": "http",
  "category": "development",
  "tags": [
    "development",
    "coding",
    "vscode",
    "pycharm",
    "xfce"
  ],
  "session_config": {
    "idle_timeout": "60m",
    "grace_period": "10m",
    "timeout_action": "stop",
    "never_timeout": false,
    "max_session_duration": null
  },
  "cap_add": [
    "CHOWN",
    "DAC_OVERRIDE",
    "FSETID",
    "FOWNER",
    "MKNOD",
    "NET_RAW",
    "SETGID",
    "SETUID",
    "SETFCAP",
    "SETPCAP",
    "NET_BIND_SERVICE",
    "SYS_CHROOT",
    "KILL",
    "AUDIT_WRITE"
  ],
  "security_opt": [
    "seccomp=unconfined",
    "apparmor=unconfined"
  ]
}
